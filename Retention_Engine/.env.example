# ── LLM ──────────────────────────────────────────────────────────────────────
# Leave blank to run in demo mode (template-based emails, no API calls)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Langfuse observability ────────────────────────────────────────────────────
# Get keys at https://cloud.langfuse.com  (leave blank to disable tracing)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Business rules ────────────────────────────────────────────────────────────
CHURN_THRESHOLD=0.5

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
